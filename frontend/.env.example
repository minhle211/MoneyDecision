# API base URL. Leave unset for dev (Vite proxies /api to localhost:8000).
# For production (e.g. Vercel): set to your backend URL including /api, e.g.:
# VITE_API_URL=https://your-backend.railway.app/api

# Optional: Firebase Auth (from Firebase Console → Project settings → General → Your apps).
# If set, Login page shows "Sign in with Firebase"; backend must have FIREBASE_SERVICE_ACCOUNT_JSON.
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
# VITE_FIREBASE_PROJECT_ID=your-project-id
# VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
# VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
# VITE_FIREBASE_APP_ID=1:123456789:web:abc123
